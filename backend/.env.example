# Neon PostgreSQL — use the DIRECT host for Flyway (no "-pooler" in hostname).
DATABASE_URL=jdbc:postgresql://ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_USERNAME=neondb_owner
DATABASE_PASSWORD=

# Activate production cookie/CORS hardening on Render:
# SPRING_PROFILES_ACTIVE=prod

# JWT — Base64-encoded secret (>= 256 bits). Required in production.
JWT_SECRET=

# CORS — include every frontend origin (Vercel production + preview if needed)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com

# true in production (HTTPS). application-prod.properties also forces this.
COOKIE_SECURE=true

# Paystack — use live keys in production (sk_live_… / pk_live_…)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_CALLBACK_URL=https://your-app.vercel.app/dashboard/subscription
