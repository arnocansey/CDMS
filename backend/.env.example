# Neon PostgreSQL — prefer the DIRECT (non-pooler) host for Flyway migrations.
# Pooler hosts look like: ep-xxxx-pooler....neon.tech
# Direct hosts look like:  ep-xxxx....neon.tech  (no "-pooler")
DATABASE_URL=jdbc:postgresql://ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_USERNAME=neondb_owner
DATABASE_PASSWORD=

# JWT — Base64-encoded secret (>= 256 bits). Change in production.
JWT_SECRET=Y2h1cmNoLWRtcy1zZWNyZXQta2V5LTIwMjYtZm9yLWp3dC10b2tlbi1nZW5lcmF0aW9u

# CORS — comma-separated; no wildcards when using credentials
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Set true behind HTTPS
COOKIE_SECURE=true

# Paystack (optional for local)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
