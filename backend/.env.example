# Neon PostgreSQL (or local)
DATABASE_URL=jdbc:postgresql://localhost:5432/church_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# JWT — Base64-encoded secret (>= 256 bits). Change in production.
JWT_SECRET=Y2h1cmNoLWRtcy1zZWNyZXQta2V5LTIwMjYtZm9yLWp3dC10b2tlbi1nZW5lcmF0aW9u

# CORS — comma-separated; no wildcards when using credentials
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Set true behind HTTPS
COOKIE_SECURE=false

# Paystack (optional for local)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
